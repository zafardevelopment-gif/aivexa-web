# Supabase project (Project Settings > API) — copy to .env.local and fill in.
# This file is a TEMPLATE — never put real keys here, it is not gitignored.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service role key — required for the /admin panel (server-side only,
# never exposed to the browser). Project Settings > API > service_role.
# NEVER commit this or use it client-side.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
